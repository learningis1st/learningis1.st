---

<BaseLayout title={title} description={description}>
	<main>
		<div class="container">
			<h1>learningis1st</h1>
			<p class="tagline">Yijia Chen</p>

			<NowPlaying />

			<div class="links" aria-label="Social links">
				{links.map((link) => (
					<SocialLink
						href={link.href}
						label={link.label}
						iconPath={link.iconPath}
						className={link.className}
						title={link.title}
						target={link.target}
						rel={link.rel}
					/>
				))}
			</div>
		</div>
	</main>

	<aside class="payment-widget" aria-label="Payments">
		<a
			class="payment-link"
			href={stripePaymentUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Make a Payment via Stripe"
			title="Make a Payment"
		>
			<svg
				class="payment-icon"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<rect x="2.75" y="5.25" width="18.5" height="13.5" rx="2.25" />
				<path d="M2.75 9.5h18.5" />
				<path d="M7 14.25h3.75" />
			</svg>
		</a>
	</aside>
</BaseLayout>
