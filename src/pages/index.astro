---

<BaseLayout title={title} description={description}>
  <main>
    <div class="container">
      <h1>learningis1st</h1>
      <p class="tagline">Yijia Chen</p>

      <NowPlaying />

      <div class="links" aria-label="Social links">
          {
            socialLinks.map((link) => (
              <Link
                type="social"
                href={link.href}
                label={link.label}
                iconPath={link.iconPath}
              />
            ))
          }
      </div>
    </div>
  </main>

  <aside class="top-widgets" aria-label="Quick Links">
      {
        topLinks.map((link) => (
          <Link
            type="top"
            href={link.href}
            label={link.label}
            icon={link.icon}
          />
        ))
      }
  </aside>
</BaseLayout>
