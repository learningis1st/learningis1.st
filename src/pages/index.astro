		label: "Twitter",
		title: "Twitter",
		className: "twitter",
		target: "_blank",
		rel: "noopener noreferrer",
		iconPath: "M23.954 4.569c-.885.389-1.83.654-2.825.775 1.014-.611 1.794-1.574 2.163-2.723-.951.555-2.005.959-3.127 1.184-.896-.959-2.178-1.559-3.594-1.559-2.717 0-4.92 2.203-4.92 4.917 0 .39.033.765.127 1.124-4.09-.2-7.72-2.163-10.148-5.144-.423.722-.666 1.561-.666 2.476 0 1.708.87 3.213 2.188 4.096-.807-.026-1.566-.248-2.228-.616v.061c0 2.385 1.693 4.374 3.946 4.827-.413.111-.849.171-1.296.171-.314 0-.615-.019-.916-.083.631 1.953 2.445 3.379 4.6 3.421-1.68 1.313-3.809 2.105-6.102 2.105-.39 0-.779-.023-1.17-.067 2.189 1.394 4.768 2.209 7.557 2.209 9.054 0 13.999-7.496 13.999-13.986 0-.209 0-.42-.015-.63.962-.689 1.8-1.56 2.46-2.548z",
	},
	{
		href: "https://t.me/learningis1st",
		label: "Telegram",
		className: "telegram",
		target: "_blank",
		rel: "noopener noreferrer",
		iconPath: "M9.78 18.65l.28-4.23 7.69-6.95c.34-.31-.08-.47-.53-.16l-9.48 5.98-4.08-1.23c-.88-.25-.89-.85.19-1.29l15.9-6.13c.75-.31 1.4.18 1.11 1.44l-2.71 12.77c-.18.91-.71 1.12-1.45.71l-4.13-3.06-1.99 1.91c-.22.22-.41.41-.8.24z",
