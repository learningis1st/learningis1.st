---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLink from "../components/SocialLink.astro";
import NowPlaying from "../components/NowPlaying.astro";

const title = "learningis1.st";
const description = "learningis1st - Connect with me on social media and email";
const stripePaymentUrl = "https://buy.stripe.com/8x2bJ25tk1zw2Yye7B38401";

type LinkItem = {
	href: string;
	label: string;
	iconPath: string;
	className?: string;
	title?: string;
	target?: string;
	rel?: string;
};

const links: LinkItem[] = [
	{
		href: "mailto:chenyijia001@gmail.com",
		label: "Email",
		className: "email",
		iconPath: "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z",
	},
	{
		href: "https://github.com/learningis1st",
		label: "GitHub",
		className: "github",
		target: "_blank",
		rel: "noopener noreferrer",
