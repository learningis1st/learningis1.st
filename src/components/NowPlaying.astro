---
import { GET } from "../pages/api/now-playing.json";

export interface Props {
	endpoint?: string;
	refreshMs?: number;
}

const { endpoint = "/api/now-playing.json", refreshMs = 10_000 } = Astro.props;
const widgetId = `now-playing-${Math.random().toString(36).slice(2, 10)}`;
let initialPayload: any = null;

// Attempt to fetch the initial payload during Server-Side Rendering (SSR).
// This prevents layout shifts and provides a snappy initial load.
try {
	const res = (await GET(Astro as any)) as Response;
	if (res.ok) {
		initialPayload = await res.json();
	}
} catch {
	// Fall back to client fetch if the server-side seed fails.
	// The client-side script will take over and attempt to fetch on mount.
}

// Derive initial UI state from the SSR payload
const hasSeedPayload = initialPayload !== null;
const track = initialPayload?.track;
const hasTrack = Boolean(track);
const isPlaying = initialPayload?.source === "playing";

const title = track?.title || "Unknown track";
const artist = track?.artist || "Unknown artist";
const album = track?.album || "Unknown album";

const metaStr = isPlaying ? `${artist} - ${album}` : artist;
const trackDisplay = isPlaying ? title : album;
const labelText = isPlaying ? "Now listening" : "Last listened album";
const coverUrl = track?.coverArtUrl || "data:,";
const progressScale = isPlaying ? (initialPayload?.progress?.percent ?? 0) / 100 : 0;

const showInitialStatus = hasSeedPayload && !hasTrack;
const initialStatusText = showInitialStatus ? "Not listening right now" : "Loading...";
---

<section
	id={widgetId}
	class="now-playing"
	aria-live="polite"
	data-state={hasSeedPayload ? "ready" : "loading"}
	data-endpoint={endpoint}
	data-refresh-ms={String(refreshMs)}
>
	<div class="now-playing__header">
		<p class="now-playing__label" data-label>{labelText}</p>
		<p class="now-playing__time" data-time hidden={!hasTrack || isPlaying}></p>
	</div>

	<div class="now-playing__content">
		<div class="now-playing__cover-wrap" data-cover-wrap hidden={!hasTrack}>
			<img class="now-playing__cover" data-cover src={coverUrl} alt="Album artwork" loading="lazy" decoding="async" />
		</div>
		<div class="now-playing__text">
			<p class="now-playing__status" data-status hidden={!showInitialStatus}>{initialStatusText}</p>
			<p class="now-playing__track" data-track hidden={!hasTrack}>{trackDisplay}</p>
			<p class="now-playing__meta" data-meta hidden={!hasTrack}>{metaStr}</p>
		</div>
	</div>

	<div class="now-playing__progress" data-progress hidden={!isPlaying}>
		<div class="now-playing__progress-bar" data-progress-bar style={`transform: scaleX(${progressScale})`}></div>
	</div>
</section>

<script is:inline define:vars={{ widgetId, initialPayload }}>
	const root = document.getElementById(widgetId);
	if (!root) throw new Error("NowPlaying root element not found.");

	const endpoint = root.dataset.endpoint ?? "/api/now-playing.json";
	const refreshMs = Number(root.dataset.refreshMs ?? "10000");

	/**
	 * Configuration for the predictive polling and animation state machine.
	 * This handles scenarios where the API only updates in "chunks" (quanta)
	 * rather than every second, preventing unnecessary API spam.
	 */
	const CFG = {
		QUANTUM_SEC: 60,              // Expected boundary chunks (e.g., API progress updates every 60s)
		MIN_POLL_SEC: 1.5,            // The absolute minimum time between API polls
		END_WINDOW_EXTRA_SEC: 0.5,    // Extra buffer added to uncertainty when nearing the end of a song
		END_POLL_RATE_SEC: 2.0,       // Fast polling rate used exclusively when crossing track boundaries
		IDLE_POLL_SEC: 30             // Slower polling rate when music is paused/stopped
	};

	// DOM Selectors
	const $ = (selector) => root.querySelector(selector);
	const els = {
		status: $("[data-status]"),
		label: $("[data-label]"),
		track: $("[data-track]"),
		meta: $("[data-meta]"),
		time: $("[data-time]"),
		coverWrap: $("[data-cover-wrap]"),
		cover: $("[data-cover]"),
		progress: $("[data-progress]"),
		progressBar: $("[data-progress-bar]")
	};

	// Application State
	const state = {
		hasLoaded: false,
		tickerId: null,   // requestAnimationFrame ID for progress bar
		fetchId: null,    // setTimeout ID for next API poll
		loadingId: null,  // setTimeout ID for delayed loading text
		trackKey: null,   // Unique identifier to detect when the actual song changes
		reqId: 0,         // Request counter to ignore stale fetch responses

		// Predictive Progress State
		basePosition: 0,       // The last known exact position from the API (in seconds)
		baseTimestamp: Date.now(), // When we received the basePosition
		uncertaintySec: CFG.QUANTUM_SEC,
		pollRateSec: 12.0,     // Current dynamic polling delay

		visualSec: 0,          // The current position shown on the visual progress bar
		durationSec: 0,        // Total track duration
		lastTick: Date.now(),  // Timestamp of the last animation frame
	};

	// --- Utilities ---
	const clampPercent = (value) => Math.max(0, Math.min(100, value));
	const getTrackKey = (t) => JSON.stringify([t?.title, t?.artist, t?.album, t?.coverArtId, t?.durationSeconds]);

	// --- Timers & Clears ---
	const stopTicker = () => {
		if (state.tickerId === null) return;
		window.cancelAnimationFrame(state.tickerId);
		state.tickerId = null;
	};

	const clearFetch = () => {
		if (state.fetchId === null) return;
		window.clearTimeout(state.fetchId);
		state.fetchId = null;
	};

	const clearLoading = () => {
		if (state.loadingId === null) return;
		window.clearTimeout(state.loadingId);
		state.loadingId = null;
	};

	const resetProgress = () => {
		Object.assign(state, {
			basePosition: 0,
			baseTimestamp: Date.now(),
			uncertaintySec: CFG.QUANTUM_SEC,
			pollRateSec: 12.0,
			visualSec: 0,
			durationSec: 0,
			trackKey: null
		});
	};

	// --- UI Updaters ---
	const markReady = () => {
		if (state.hasLoaded) return;
		state.hasLoaded = true;
		root.dataset.state = "ready";
	};

	const showLoadingWithDelay = () => {
		clearLoading();
		if (!els.status) return;

		// Prevent layout flicker by waiting slightly before showing "Loading"
		state.loadingId = window.setTimeout(() => {
			els.status.textContent = "Loading...";
			els.status.hidden = false;
			state.loadingId = null;
		}, 400);
	};

	const setTextContent = (el, text, transitionMs = 150) => {
		if (!el || el.textContent === text) return;
		el.classList.add("transitioning");
		setTimeout(() => {
			el.textContent = text;
			el.classList.remove("transitioning");
		}, transitionMs);
	};

	const setLabelText = (text) => setTextContent(els.label, text, 200);

	const setIdleState = (message) => {
		setLabelText("Last listened album");

		if (els.status) {
			els.status.textContent = message;
			els.status.hidden = false;
		}

		if (els.track) els.track.hidden = true;
		if (els.meta) els.meta.hidden = true;
		if (els.time) els.time.hidden = true;
		if (els.coverWrap) els.coverWrap.hidden = true;

		resetProgress();
		stopTicker();

		if (els.progress) els.progress.hidden = true;
		if (els.progressBar) els.progressBar.style.transform = "scaleX(0)";

		markReady();
	};

	const setCover = (url) => {
		const { coverWrap, cover } = els;
		if (!coverWrap || !cover) return;

		if (!url) {
			coverWrap.classList.add("transitioning");
			setTimeout(() => {
				coverWrap.hidden = true;
				cover.removeAttribute("src");
				coverWrap.classList.remove("transitioning");
			}, 150);
			return;
		}

		if (cover.getAttribute("src") === url) return;

		coverWrap.classList.add("transitioning");
		setTimeout(() => {
			coverWrap.hidden = false;
			cover.onload = cover.onerror = () => {
				coverWrap.classList.remove("transitioning");
				cover.onload = cover.onerror = null;
			};
			cover.src = url;
		}, 150);
	};

	const setProgress = (percent, shouldShow) => {
		if (!els.progress || !els.progressBar) return;

		if (!shouldShow || typeof percent !== "number") {
			els.progress.hidden = true;
			els.progressBar.style.transform = "scaleX(0)";
			return;
		}

		els.progress.hidden = false;
		els.progressBar.style.transform = `scaleX(${clampPercent(percent) / 100})`;
	};

	// --- Animation & Predictive Logic ---

	/**
	 * Calculates and renders the progress bar based on estimated time passed.
	 * Includes "catch up" and "coast" logic to handle discrepancies between
	 * the smooth visual progress and chunked API updates.
	 */
	const renderEstimatedProgress = () => {
		if (state.durationSec <= 0) return;

		const now = Date.now();
		const deltaTickSec = Math.max(0, (now - state.lastTick) / 1000);
		state.lastTick = now;

		const elapsedSinceBaseSec = Math.max(0, (now - state.baseTimestamp) / 1000);
		const maxAllowedSec = state.basePosition + CFG.QUANTUM_SEC;
		const targetSec = Math.min(state.basePosition + elapsedSinceBaseSec, maxAllowedSec, state.durationSec);

		// Distance between our visual bar and the estimated real position
		const distanceSec = targetSec - state.visualSec;

		let speed = 1.0;
		if (distanceSec > 0.5) {
			// Visuals are behind: smoothly speed up to catch up
			speed = 1.0 + (distanceSec / 5.0);
		} else if (distanceSec < -5.0) {
			// Visuals are vastly ahead (e.g. user rewound the track): hard reset position
			state.visualSec = targetSec;
			speed = 1.0;
		} else if (distanceSec < 0) {
			// Visuals are slightly ahead: slow down and let real time catch up
			speed = 0.5;
		}

		state.visualSec += speed * deltaTickSec;
		state.visualSec = Math.max(0, Math.min(state.visualSec, state.durationSec));

		setProgress((state.visualSec / state.durationSec) * 100, true);

		if (state.visualSec >= state.durationSec) stopTicker();
	};

	const tickProgress = () => {
		if (!document.contains(root)) return stopTicker();
		renderEstimatedProgress();
		if (state.tickerId !== null) {
			state.tickerId = window.requestAnimationFrame(tickProgress);
		}
	};

	const startTicker = () => {
		if (state.tickerId !== null) return;
		state.lastTick = Date.now();
		state.tickerId = window.requestAnimationFrame(tickProgress);
	};

	const formatRelativeTime = (iso) => {
		const ts = Date.parse(iso);
		if (Number.isNaN(ts)) return "";

		const mins = Math.max(1, Math.floor((Date.now() - ts) / 60000));
		if (mins < 60) return `${mins}m ago`;

		const hrs = Math.floor(mins / 60);
		if (hrs < 24) return `${hrs}h ago`;

		return `${Math.floor(hrs / 24)}d ago`;
	};

	// --- Core Network & State Handling ---

	const scheduleNextFetch = (delayMs) => {
		clearFetch();
		if (!document.contains(root)) return;
		state.fetchId = window.setTimeout(() => void fetchNowPlaying(), Math.max(1000, delayMs));
	};

	/**
	 * Ingests a payload from the API, updates UI state, and calculates
	 * the most optimal delay before the next API fetch.
	 */
	const handlePayload = (payload, fetchStartMs) => {
		clearLoading();

		// 1. Handle Empty/Idle State
		if (!payload?.track) {
			setIdleState("Not listening right now");
			return CFG.IDLE_POLL_SEC * 1000;
		}

		const { track, source, lastPlayedAt } = payload;

		if (els.status) els.status.hidden = true;
		if (els.track) els.track.hidden = false;
		if (els.meta) els.meta.hidden = false;

		setCover(track.coverArtUrl);
		markReady();

		const title = track.title || "Unknown track";
		const metaStr = `${track.artist || "Unknown artist"} - ${track.album || "Unknown album"}`;

		// 2. Handle Paused / Historic Playback
		if (source !== "playing") {
			setTextContent(els.track, track.album || "Unknown album");
			setTextContent(els.meta, track.artist || "Unknown artist");
			setLabelText("Last listened album");

			resetProgress();
			stopTicker();
			setProgress(0, false);

			const relTime = formatRelativeTime(lastPlayedAt);
			if (els.time) {
				els.time.hidden = !relTime;
				if (relTime) els.time.textContent = relTime;
			}
			return CFG.IDLE_POLL_SEC * 1000;
		}

		// 3. Handle Active Playback
		setTextContent(els.track, title);
		setTextContent(els.meta, metaStr);
		setLabelText("Now listening");
		if (els.time) els.time.hidden = true;

		const trackKey = getTrackKey(track);
		const rawSec = Math.max(0, payload.progress?.positionSeconds || 0);
		const durationSec = track.durationSeconds || 0;
		const timestamp = fetchStartMs || Date.now();

		let triggerBoundarySleep = false;

		// State Machine: Detect song changes, rewinds, or natural chunk progression
		if (trackKey !== state.trackKey) {
			const isFirstLoad = state.trackKey === null;
			state.trackKey = trackKey;
			state.basePosition = rawSec;
			state.baseTimestamp = timestamp;
			state.visualSec = rawSec;

			if (isFirstLoad) {
				state.uncertaintySec = CFG.QUANTUM_SEC;
				state.pollRateSec = 12.0;
			} else {
				// NEW SONG DETECTED: Assume we are already synced via webhooks/cache!
				state.uncertaintySec = 3.0;
				state.pollRateSec = 1.5;
				triggerBoundarySleep = true;
			}
		} else if (rawSec < state.basePosition) {
			// Rewind detected
			state.basePosition = rawSec;
			state.baseTimestamp = timestamp;
			state.uncertaintySec = CFG.QUANTUM_SEC;
			state.pollRateSec = 12.0;
		} else if (rawSec > state.basePosition) {
			// Standard chunk boundary crossed (normal playback progression)
			state.basePosition = rawSec;
			state.baseTimestamp = timestamp;
			state.uncertaintySec = state.pollRateSec;
			state.pollRateSec = Math.max(CFG.MIN_POLL_SEC, state.pollRateSec / 2);
			triggerBoundarySleep = true;
		}

		state.durationSec = durationSec;
		renderEstimatedProgress();
		startTicker();

		// --- Polling Strategy Math ---
		const elapsedSinceBaseSec = Math.max(0, (Date.now() - state.baseTimestamp) / 1000);
		const estimatedPos = state.basePosition + elapsedSinceBaseSec;
		const remainingSec = Math.max(0, state.durationSec - estimatedPos);

		let nextDelayMs;

		if (triggerBoundarySleep) {
			// Chunk changed (or synced new track): calculate maximum safe sleep
			const sleepSec = CFG.QUANTUM_SEC - state.uncertaintySec;
			nextDelayMs = sleepSec * 1000;
		} else {
			// Normal mid-chunk polling: fallback to standard dynamic poll rate
			nextDelayMs = state.pollRateSec * 1000;
		}

		// CRITICAL: Ensure we never sleep through the end-of-song window.
		// We want to burst-poll right as the track naturally ends to catch the next song instantly.
		const currentEndWindowSec = state.uncertaintySec + CFG.END_WINDOW_EXTRA_SEC;

		if (state.durationSec > 0) {
			if (remainingSec <= currentEndWindowSec) {
				// Inside the end-of-song boundary override with burst poll.
				nextDelayMs = CFG.END_POLL_RATE_SEC * 1000;
			} else {
				// Cap the current sleep delay to guarantee we wake up exactly as the end-window begins.
				const timeUntilEndWindowMs = (remainingSec - currentEndWindowSec) * 1000;
				nextDelayMs = Math.max(CFG.END_POLL_RATE_SEC * 1000, Math.min(nextDelayMs, timeUntilEndWindowMs));
			}
		}

		return nextDelayMs;
	};

	const fetchNowPlaying = async () => {
		if (!document.contains(root)) return;

		const reqId = ++state.reqId; // Keep track of current request to avoid race conditions
		if (!state.hasLoaded) showLoadingWithDelay();

		const fetchStartMs = Date.now();

		try {
			const res = await fetch(endpoint, {
				headers: { Accept: "application/json" },
				cache: "no-store",
			});

			// Abort if a newer request was initiated while this one was pending
			if (reqId !== state.reqId) return;
			if (!res.ok) throw new Error("Fetch failed");

			const payload = await res.json();
			if (reqId !== state.reqId) return;

			const nextDelayMs = handlePayload(payload, fetchStartMs);
			scheduleNextFetch(nextDelayMs);

		} catch {
			if (reqId !== state.reqId) return;
			clearLoading();
			setIdleState("Unable to load now-playing widget");

			// On failure, fall back to the default fallback refresh rate
			scheduleNextFetch(refreshMs);
		}
	};

	// --- Initialization ---
	if (initialPayload) {
		// If SSR provided data, bootstrap immediately without fetching
		const nextDelayMs = handlePayload(initialPayload, Date.now());
		scheduleNextFetch(nextDelayMs);
	} else {
		// Otherwise, kick off a client-side fetch
		void fetchNowPlaying();
	}
</script>
