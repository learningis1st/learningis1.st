---
export interface Props {
	endpoint?: string;
	refreshMs?: number;
}

const { endpoint = "/api/now-playing.json", refreshMs = 10_000 } = Astro.props;
const widgetId = `now-playing-${Math.random().toString(36).slice(2, 10)}`;
---

<section
	id={widgetId}
	class="now-playing"
	aria-live="polite"
	data-state="loading"
	data-endpoint={endpoint}
	data-refresh-ms={String(refreshMs)}
>
	<div class="now-playing__header">
		<p class="now-playing__label" data-label>Listening</p>
		<p class="now-playing__time" data-time hidden></p>
	</div>
	<div class="now-playing__content">
		<div class="now-playing__cover-wrap" data-cover-wrap hidden>
			<img class="now-playing__cover" data-cover src="data:," alt="Album artwork" loading="lazy" decoding="async" />
		</div>
		<div class="now-playing__text">
			<p class="now-playing__status" data-status>Loading...</p>
			<p class="now-playing__track" data-track hidden></p>
			<p class="now-playing__meta" data-meta hidden></p>
		</div>
	</div>
	<div class="now-playing__progress" data-progress hidden>
		<div class="now-playing__progress-bar" data-progress-bar></div>
	</div>
</section>

<script is:inline define:vars={{ widgetId }}>
	const root = document.getElementById(widgetId);
	if (!root) {
		throw new Error("NowPlaying root element not found.");
	}

	const endpoint = root.dataset.endpoint ?? "/api/now-playing.json";
	const refreshMs = Number(root.dataset.refreshMs ?? "10000");
	const idleRefreshMs = 30_000;

	const statusEl = root.querySelector("[data-status]");
	const labelEl = root.querySelector("[data-label]");
	const trackEl = root.querySelector("[data-track]");
	const metaEl = root.querySelector("[data-meta]");
	const timeEl = root.querySelector("[data-time]");
	const coverWrapEl = root.querySelector("[data-cover-wrap]");
	const coverEl = root.querySelector("[data-cover]");
	const progressEl = root.querySelector("[data-progress]");
	const progressBarEl = root.querySelector("[data-progress-bar]");

	let hasLoadedOnce = false;
	let progressTickerId = null;
	let fetchTimerId = null;
	let currentTrackKey = null;
	let targetPositionSeconds = 0;
	let visualPositionSeconds = 0;
	let lastKnownMinutesAgo = 0;
	let lastTickTime = Date.now();
	let trackDurationSeconds = 0;
	let latestRequestId = 0;
	let isSynced = false;

	const clampPercent = (value) => Math.max(0, Math.min(100, value));

	const getTrackKey = (track) =>
		JSON.stringify({
			title: track?.title ?? "",
			artist: track?.artist ?? "",
			album: track?.album ?? "",
			coverArtId: track?.coverArtId ?? null,
			durationSeconds: track?.durationSeconds ?? null,
		});

	const stopProgressTicker = () => {
		if (progressTickerId !== null) {
			window.cancelAnimationFrame(progressTickerId);
			progressTickerId = null;
		}
	};

	const resetProgressState = () => {
		targetPositionSeconds = 0;
		visualPositionSeconds = 0;
		lastKnownMinutesAgo = 0;
		lastTickTime = Date.now();
		trackDurationSeconds = 0;
		currentTrackKey = null;
		isSynced = false;
	};

	const clearFetchTimer = () => {
		if (fetchTimerId !== null) {
			window.clearTimeout(fetchTimerId);
			fetchTimerId = null;
		}
	};

	const scheduleNextFetch = (delayMs) => {
		clearFetchTimer();
		if (!document.contains(root)) return;

		fetchTimerId = window.setTimeout(() => {
			void fetchNowPlaying();
		}, Math.max(1_000, delayMs));
	};

	const markReady = () => {
		if (hasLoadedOnce) return;
		hasLoadedOnce = true;
		root.dataset.state = "ready";
	};

	const setTextContent = (el, text) => {
		if (!(el instanceof HTMLElement) || el.textContent === text) return;

		el.classList.add("transitioning");
		setTimeout(() => {
			el.textContent = text;
			el.classList.remove("transitioning");
		}, 150);
	};

	const setIdleState = (message) => {
		if (!(statusEl instanceof HTMLElement) || !(trackEl instanceof HTMLElement) ||
			!(metaEl instanceof HTMLElement) || !(timeEl instanceof HTMLElement) ||
			!(coverWrapEl instanceof HTMLElement) || !(progressEl instanceof HTMLElement)) {
			return;
		}

		setTextContent(labelEl, "Listening");
		statusEl.textContent = message;
		statusEl.hidden = false;
		trackEl.hidden = true;
		metaEl.hidden = true;
		timeEl.hidden = true;
		coverWrapEl.hidden = true;

		resetProgressState();
		stopProgressTicker();
		progressEl.hidden = true;

		if (progressBarEl instanceof HTMLElement) {
			progressBarEl.style.transform = "scaleX(0)";
		}
		markReady();
	};

	const setCover = (url) => {
		if (!(coverWrapEl instanceof HTMLElement) || !(coverEl instanceof HTMLImageElement)) return;

		if (!url) {
			coverWrapEl.classList.add("transitioning");
			setTimeout(() => {
				coverWrapEl.hidden = true;
				coverEl.removeAttribute("src");
				coverWrapEl.classList.remove("transitioning");
			}, 150);
			return;
		}

		if (coverEl.getAttribute("src") === url) return;

		coverWrapEl.classList.add("transitioning");
		setTimeout(() => {
			coverWrapEl.hidden = false;
			coverEl.onload = () => {
				coverWrapEl.classList.remove("transitioning");
				coverEl.onload = null;
			};
			coverEl.onerror = () => {
				coverWrapEl.classList.remove("transitioning");
				coverEl.onerror = null;
			};
			coverEl.src = url;
		}, 150);
	};

	const setProgress = (percent, shouldShow) => {
		if (!(progressEl instanceof HTMLElement) || !(progressBarEl instanceof HTMLElement)) return;

		if (!shouldShow || typeof percent !== "number") {
			progressEl.hidden = true;
			progressBarEl.style.transform = "scaleX(0)";
			return;
		}

		progressEl.hidden = false;
		progressBarEl.style.transform = `scaleX(${clampPercent(percent) / 100})`;
	};

	const renderEstimatedProgress = () => {
		if (trackDurationSeconds <= 0) return;

		const now = Date.now();
		const elapsedSeconds = Math.max(0, (now - lastTickTime) / 1000);
		lastTickTime = now;

		// Advance estimated target at real-time speed between polling responses.
		targetPositionSeconds += elapsedSeconds;

		// Keep the estimate inside the current minute bucket until the API confirms the next one.
		const maxAllowedTarget = Math.max(0, ((lastKnownMinutesAgo + 1) * 60) - 1);
		targetPositionSeconds = Math.min(targetPositionSeconds, maxAllowedTarget, trackDurationSeconds);

		const distance = targetPositionSeconds - visualPositionSeconds;
		visualPositionSeconds += distance * 0.1;
		visualPositionSeconds = Math.min(Math.max(0, visualPositionSeconds), trackDurationSeconds);

		const percent = (visualPositionSeconds / trackDurationSeconds) * 100;

		setProgress(percent, true);
		if (visualPositionSeconds >= trackDurationSeconds - 0.5) {
			stopProgressTicker();
		}
	};

	const tickProgress = () => {
		if (!document.contains(root)) {
			stopProgressTicker();
			return;
		}

		renderEstimatedProgress();
		if (progressTickerId !== null) {
			progressTickerId = window.requestAnimationFrame(tickProgress);
		}
	};

	const startProgressTicker = () => {
		if (progressTickerId !== null) return;
		lastTickTime = Date.now();
		progressTickerId = window.requestAnimationFrame(tickProgress);
	};

	const setProgressSnapshot = (progress, durationSeconds, shouldShow, trackKey) => {
		if (!shouldShow || !progress || typeof progress.positionSeconds !== "number" ||
			typeof durationSeconds !== "number" || durationSeconds <= 0) {
			resetProgressState();
			stopProgressTicker();
			setProgress(0, false);
			return;
		}

		trackDurationSeconds = durationSeconds;
		const rawSeconds = Math.max(0, progress.positionSeconds);
		const incomingMinutesAgo = Math.max(0, Math.floor(rawSeconds / 60));

		if (trackKey !== currentTrackKey) {
			currentTrackKey = trackKey;
			lastKnownMinutesAgo = incomingMinutesAgo;
			isSynced = false;

			const midpointGuess = incomingMinutesAgo === 0 ? 0 : rawSeconds + 30;
			targetPositionSeconds = Math.min(midpointGuess, trackDurationSeconds);
			visualPositionSeconds = Math.min(rawSeconds, trackDurationSeconds);
			lastTickTime = Date.now();
		} else if (incomingMinutesAgo > lastKnownMinutesAgo || incomingMinutesAgo < lastKnownMinutesAgo) {
			// Boundary detection: once the minute bucket changes, we know the exact snapped position.
			targetPositionSeconds = Math.min(incomingMinutesAgo * 60, trackDurationSeconds);
			lastKnownMinutesAgo = incomingMinutesAgo;
			isSynced = true;
		}

		renderEstimatedProgress();
		startProgressTicker();
	};

	const formatRelativeTime = (isoTimestamp) => {
		const timestamp = Date.parse(isoTimestamp);
		if (Number.isNaN(timestamp)) return "";

		const minutes = Math.max(1, Math.floor((Date.now() - timestamp) / 60_000));
		if (minutes < 60) return `${minutes}m ago`;

		const hours = Math.floor(minutes / 60);
		if (hours < 24) return `${hours}h ago`;

		const days = Math.floor(hours / 24);
		return `${days}d ago`;
	};

	const renderData = (payload) => {
		if (!(statusEl instanceof HTMLElement) || !(trackEl instanceof HTMLElement) ||
			!(metaEl instanceof HTMLElement) || !(timeEl instanceof HTMLElement)) {
			return;
		}

		if (!payload || !payload.track) {
			setIdleState("Not listening right now");
			return;
		}

		statusEl.hidden = true;
		trackEl.hidden = false;
		metaEl.hidden = false;
		setCover(payload.track.coverArtUrl);
		markReady();

		const trackTitle = payload.track.title || "Unknown track";
		const trackMeta = `${payload.track.artist || "Unknown artist"} - ${payload.track.album || "Unknown album"}`;

		if (payload.source === "playing") {
			setTextContent(trackEl, trackTitle);
			setTextContent(metaEl, trackMeta);
			setTextContent(labelEl, "Now listening");
			timeEl.hidden = true;
			setProgressSnapshot(payload.progress, payload.track.durationSeconds, true, getTrackKey(payload.track));
			return;
		}

		setTextContent(trackEl, payload.track.album || "Unknown album");
		setTextContent(metaEl, payload.track.artist || "Unknown artist");
		setTextContent(labelEl, "Last listened album");
		setProgressSnapshot(null, null, false, null);

		const relativeTime = formatRelativeTime(payload.lastPlayedAt);
		if (!relativeTime) {
			timeEl.hidden = true;
			return;
		}

		timeEl.hidden = false;
		timeEl.textContent = relativeTime;
	};

	const fetchNowPlaying = async () => {
		if (!document.contains(root)) return;

		const requestId = ++latestRequestId;
		try {
			const response = await fetch(endpoint, {
				headers: { Accept: "application/json" },
				cache: "no-store",
			});

			if (requestId !== latestRequestId) return;

			if (!response.ok) {
				setIdleState("Unable to load current track");
				scheduleNextFetch(refreshMs);
				return;
			}

			const payload = await response.json();
			if (requestId !== latestRequestId) return;

			renderData(payload);
			let nextDelay = idleRefreshMs;

			if (payload?.isPlaying) {
				const secondsToNextBoundary = ((lastKnownMinutesAgo + 1) * 60) - targetPositionSeconds;
				const secondsToEnd = Math.max(0, trackDurationSeconds - targetPositionSeconds);

				if (isSynced) {
					// Once synced to a bucket flip, hit just after the next expected boundary/end.
					const nextEventSeconds = Math.min(secondsToNextBoundary, secondsToEnd);
					nextDelay = (nextEventSeconds + 1.5) * 1000;
				} else {
					// Unsynced mode narrows uncertainty window as we approach the next boundary.
					const stallPoint = (lastKnownMinutesAgo + 1) * 60;
					const secondsToStall = Math.max(0, stallPoint - targetPositionSeconds);
					if (secondsToStall > 0) {
						nextDelay = (secondsToStall / 2) * 1000;
					} else {
						nextDelay = 5_000;
					}
				}

				nextDelay = Math.min(refreshMs, nextDelay);
				nextDelay = Math.max(2_000, nextDelay);
			}

			scheduleNextFetch(nextDelay);
		} catch (_error) {
			if (requestId !== latestRequestId) return;
			setIdleState("Unable to load current track");
			scheduleNextFetch(refreshMs);
		}
	};

	void fetchNowPlaying();
</script>
