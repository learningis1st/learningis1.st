---
export interface Props {
	endpoint?: string;
	refreshMs?: number;
}

const { endpoint = "/api/now-playing.json", refreshMs = 10_000 } = Astro.props;
const widgetId = `now-playing-${Math.random().toString(36).slice(2, 10)}`;
---

<section
	id={widgetId}
	class="now-playing"
	aria-live="polite"
	data-state="loading"
	data-endpoint={endpoint}
	data-refresh-ms={String(refreshMs)}
>
	<div class="now-playing__header">
		<p class="now-playing__label" data-label>Now Listening</p>
		<p class="now-playing__time" data-time hidden></p>
	</div>
	<div class="now-playing__content">
		<div class="now-playing__cover-wrap" data-cover-wrap hidden>
			<img class="now-playing__cover" data-cover src="data:," alt="Album artwork" loading="lazy" decoding="async" />
		</div>
		<div class="now-playing__text">
			<p class="now-playing__status" data-status hidden>Loading...</p>
			<p class="now-playing__track" data-track hidden></p>
			<p class="now-playing__meta" data-meta hidden></p>
		</div>
	</div>
	<div class="now-playing__progress" data-progress hidden>
		<div class="now-playing__progress-bar" data-progress-bar></div>
	</div>
</section>

<script is:inline define:vars={{ widgetId }}>
	const root = document.getElementById(widgetId);
	if (!root) throw new Error("NowPlaying root element not found.");

	const endpoint = root.dataset.endpoint ?? "/api/now-playing.json";
	const refreshMs = Number(root.dataset.refreshMs ?? "10000");
	const idleRefreshMs = 30_000;

	const $ = (selector) => root.querySelector(selector);
	const els = {
		status: $("[data-status]"),
		label: $("[data-label]"),
		track: $("[data-track]"),
		meta: $("[data-meta]"),
		time: $("[data-time]"),
		coverWrap: $("[data-cover-wrap]"),
		cover: $("[data-cover]"),
		progress: $("[data-progress]"),
		progressBar: $("[data-progress-bar]")
	};

	const state = {
		hasLoaded: false,
		tickerId: null,
		fetchId: null,
		loadingId: null,
		trackKey: null,
		targetSec: 0,
		visualSec: 0,
		lastMinsAgo: 0,
		lastTick: Date.now(),
		durationSec: 0,
		reqId: 0,
		isSynced: false
	};

	const clampPercent = (value) => Math.max(0, Math.min(100, value));

	const getTrackKey = (t) => JSON.stringify([t?.title, t?.artist, t?.album, t?.coverArtId, t?.durationSeconds]);

	const stopTicker = () => {
		if (state.tickerId === null) return;
		window.cancelAnimationFrame(state.tickerId);
		state.tickerId = null;
	};

	const clearFetch = () => {
		if (state.fetchId === null) return;
		window.clearTimeout(state.fetchId);
		state.fetchId = null;
	};

	const clearLoading = () => {
		if (state.loadingId === null) return;
		window.clearTimeout(state.loadingId);
		state.loadingId = null;
	};

	const resetProgress = () => {
		Object.assign(state, {
			targetSec: 0,
			visualSec: 0,
			lastMinsAgo: 0,
			lastTick: Date.now(),
			durationSec: 0,
			trackKey: null,
			isSynced: false
		});
	};

	const scheduleNextFetch = (delayMs) => {
		clearFetch();
		if (!document.contains(root)) return;
		state.fetchId = window.setTimeout(() => void fetchNowPlaying(), Math.max(1_000, delayMs));
	};

	const markReady = () => {
		if (state.hasLoaded) return;
		state.hasLoaded = true;
		root.dataset.state = "ready";
	};

	const showLoadingWithDelay = () => {
		clearLoading();
		if (!els.status) return;

		state.loadingId = window.setTimeout(() => {
			els.status.textContent = "Loading...";
			els.status.hidden = false;
			state.loadingId = null;
		}, 400);
	};

	const setTextContent = (el, text) => {
		if (!el || el.textContent === text) return;
		el.classList.add("transitioning");
		setTimeout(() => {
			el.textContent = text;
			el.classList.remove("transitioning");
		}, 150);
	};

	const setLabelText = (text) => {
		if (els.label && els.label.textContent !== text) {
			els.label.textContent = text;
		}
	};

	const setIdleState = (message) => {
		setLabelText("Now Listening");

		if (els.status) {
			els.status.textContent = message;
			els.status.hidden = false;
		}
		if (els.track) els.track.hidden = true;
		if (els.meta) els.meta.hidden = true;
		if (els.time) els.time.hidden = true;
		if (els.coverWrap) els.coverWrap.hidden = true;

		resetProgress();
		stopTicker();

		if (els.progress) els.progress.hidden = true;
		if (els.progressBar) els.progressBar.style.transform = "scaleX(0)";

		markReady();
	};

	const setCover = (url) => {
		const { coverWrap, cover } = els;
		if (!coverWrap || !cover) return;

		if (!url) {
			coverWrap.classList.add("transitioning");
			setTimeout(() => {
				coverWrap.hidden = true;
				cover.removeAttribute("src");
				coverWrap.classList.remove("transitioning");
			}, 150);
			return;
		}

		if (cover.getAttribute("src") === url) return;

		coverWrap.classList.add("transitioning");
		setTimeout(() => {
			coverWrap.hidden = false;
			cover.onload = cover.onerror = () => {
				coverWrap.classList.remove("transitioning");
				cover.onload = cover.onerror = null;
			};
			cover.src = url;
		}, 150);
	};

	const setProgress = (percent, shouldShow) => {
		if (!els.progress || !els.progressBar) return;

		if (!shouldShow || typeof percent !== "number") {
			els.progress.hidden = true;
			els.progressBar.style.transform = "scaleX(0)";
			return;
		}

		els.progress.hidden = false;
		els.progressBar.style.transform = `scaleX(${clampPercent(percent) / 100})`;
	};

	const renderEstimatedProgress = () => {
		if (state.durationSec <= 0) return;

		const now = Date.now();
		const elapsedSec = Math.max(0, (now - state.lastTick) / 1000);
		state.lastTick = now;

		state.targetSec += elapsedSec;
		const maxAllowed = Math.max(0, ((state.lastMinsAgo + 1) * 60) - 1);
		state.targetSec = Math.min(state.targetSec, maxAllowed, state.durationSec);

		const distance = state.targetSec - state.visualSec;
		state.visualSec += distance * 0.1;
		state.visualSec = Math.min(Math.max(0, state.visualSec), state.durationSec);

		setProgress((state.visualSec / state.durationSec) * 100, true);

		if (state.visualSec >= state.durationSec - 0.5) stopTicker();
	};

	const tickProgress = () => {
		if (!document.contains(root)) {
			stopTicker();
			return;
		}
		renderEstimatedProgress();
		if (state.tickerId !== null) {
			state.tickerId = window.requestAnimationFrame(tickProgress);
		}
	};

	const startTicker = () => {
		if (state.tickerId !== null) return;
		state.lastTick = Date.now();
		state.tickerId = window.requestAnimationFrame(tickProgress);
	};

	const setProgressSnapshot = (progress, durationSec, shouldShow, trackKey) => {
		if (!shouldShow || !progress || typeof progress.positionSeconds !== "number" || typeof durationSec !== "number" || durationSec <= 0) {
			resetProgress();
			stopTicker();
			setProgress(0, false);
			return;
		}

		state.durationSec = durationSec;
		const rawSec = Math.max(0, progress.positionSeconds);
		const minsAgo = Math.max(0, Math.floor(rawSec / 60));

		if (trackKey !== state.trackKey) {
			state.trackKey = trackKey;
			state.lastMinsAgo = minsAgo;
			state.isSynced = false;

			const midpointGuess = minsAgo === 0 ? 0 : rawSec + 30;
			state.targetSec = Math.min(midpointGuess, state.durationSec);
			state.visualSec = Math.min(rawSec, state.durationSec);
			state.lastTick = Date.now();
		} else if (minsAgo !== state.lastMinsAgo) {
			state.targetSec = Math.min(minsAgo * 60, state.durationSec);
			state.lastMinsAgo = minsAgo;
			state.isSynced = true;
		}

		renderEstimatedProgress();
		startTicker();
	};

	const formatRelativeTime = (iso) => {
		const ts = Date.parse(iso);
		if (Number.isNaN(ts)) return "";

		const mins = Math.max(1, Math.floor((Date.now() - ts) / 60_000));
		if (mins < 60) return `${mins}m ago`;

		const hrs = Math.floor(mins / 60);
		if (hrs < 24) return `${hrs}h ago`;

		return `${Math.floor(hrs / 24)}d ago`;
	};

	const renderData = (payload) => {
		clearLoading();

		if (!payload?.track) return setIdleState("Not listening right now");

		const { track, source, lastPlayedAt } = payload;

		if (els.status) els.status.hidden = true;
		if (els.track) els.track.hidden = false;
		if (els.meta) els.meta.hidden = false;

		setCover(track.coverArtUrl);
		markReady();

		const title = track.title || "Unknown track";
		const metaStr = `${track.artist || "Unknown artist"} - ${track.album || "Unknown album"}`;

		if (source === "playing") {
			setTextContent(els.track, title);
			setTextContent(els.meta, metaStr);
			setLabelText("Now listening");
			if (els.time) els.time.hidden = true;
			setProgressSnapshot(payload.progress, track.durationSeconds, true, getTrackKey(track));
			return;
		}

		setTextContent(els.track, track.album || "Unknown album");
		setTextContent(els.meta, track.artist || "Unknown artist");
		setLabelText("Last listened album");
		setProgressSnapshot(null, null, false, null);

		const relTime = formatRelativeTime(lastPlayedAt);
		if (els.time) {
			els.time.hidden = !relTime;
			if (relTime) els.time.textContent = relTime;
		}
	};

	const fetchNowPlaying = async () => {
		if (!document.contains(root)) return;

		const reqId = ++state.reqId;
		showLoadingWithDelay();

		try {
			const res = await fetch(endpoint, {
				headers: { Accept: "application/json" },
				cache: "no-store",
			});

			if (reqId !== state.reqId) return;

			if (!res.ok) throw new Error("Fetch failed");

			const payload = await res.json();
			if (reqId !== state.reqId) return;

			renderData(payload);

			let nextDelay = idleRefreshMs;
			if (payload?.isPlaying) {
				const secsToNextBound = ((state.lastMinsAgo + 1) * 60) - state.targetSec;
				const secsToEnd = Math.max(0, state.durationSec - state.targetSec);

				if (state.isSynced) {
					nextDelay = (Math.min(secsToNextBound, secsToEnd) + 1.5) * 1000;
				} else {
					const secsToStall = Math.max(0, ((state.lastMinsAgo + 1) * 60) - state.targetSec);
					nextDelay = secsToStall > 0 ? (secsToStall / 2) * 1000 : 5000;
				}
				nextDelay = Math.max(2_000, Math.min(refreshMs, nextDelay));
			}

			scheduleNextFetch(nextDelay);
		} catch {
			if (reqId !== state.reqId) return;
			clearLoading();
			setIdleState("Unable to load current track");
			scheduleNextFetch(refreshMs);
		}
	};

	void fetchNowPlaying();
</script>
